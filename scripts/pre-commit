#!/bin/sh
#
# Pre-commit hook: blocks commits containing Ethereum private keys
# or other high-entropy secrets in staged files.
#
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

# Check for Ethereum private keys (0x + 64 hex chars)
if git diff --cached --diff-filter=ACM -z | xargs -0 grep -Pn '0x[0-9a-fA-F]{64}' 2>/dev/null; then
  echo ""
  echo "ERROR: Staged files contain what appears to be an Ethereum private key."
  echo "Remove the secret and use environment variables instead."
  echo ""
  exit 1
fi

# Check for PRIVATE_KEY= assignments with inline values
if git diff --cached --diff-filter=ACM -z | xargs -0 grep -Pn 'PRIVATE_KEY\s*=\s*0x[0-9a-fA-F]+' 2>/dev/null; then
  echo ""
  echo "ERROR: Staged files contain an inline PRIVATE_KEY assignment."
  echo "Use .env.local (gitignored) for secrets."
  echo ""
  exit 1
fi

exit 0
